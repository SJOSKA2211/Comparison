[MESSAGES CONTROL]
# Disable the message, report, category or checker with the given id(s).
# C0114: Missing module docstring
# C0115: Missing class docstring
# C0116: Missing function or method docstring
# R0903: Too few public methods (common for Pydantic models)
# W1203: Use lazy % formatting in logging
# E0401: Unable to import (environment specific)
# E0611: No name in module (often triggered by Pydantic/dynamic imports)
# R0913: Too many arguments (numerical methods need many args)
# R0914: Too many local variables
# R0917: Too many positional arguments
# W0718: Catching too general exception (sometimes necessary)
# R0902: Too many instance attributes
# C0103: Invalid name (enforced by ruff differently, keeping pylint loose)
# C0301: Line too long (handled by ruff)
# C0303: Trailing whitespace (handled by ruff)
# W0311: Bad indentation (handled by ruff)
# C0411: Wrong import order (handled by ruff)
# C0414: Useless import alias (sometimes useful for re-exports)
# C0415: Import outside toplevel (sometimes necessary for circular deps)
# W0613: Unused argument (often needed for API signatures)
# W0621: Redefining name from outer scope (common in tests/scripts)
# W0707: Raise missing from
# W1514: Using open without encoding
# W0107: Unnecessary pass statement
# W0612: Unused variable
disable=C0114,C0115,C0116,R0903,W1203,E0401,E0611,R0913,R0914,R0917,W0718,R0902,C0103,C0301,C0303,W0311,C0411,C0414,C0415,W0613,W0621,W0707,W1514,W0107,W0612

[FORMAT]
# Maximum number of characters on a single line.
max-line-length=100

[MASTER]
# A comma-separated list of package or module names from where C extensions may
# be loaded. Extensions are loading into the active Python interpreter and may
# run arbitrary code.
extension-pkg-whitelist=pydantic
